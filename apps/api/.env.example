# API configuration (copy to .env for local dev; never commit real secrets).
NODE_ENV=development
PORT=3000

# Auth: 'dev' (username-only DevAuth, non-prod) or 'ldap' (not yet implemented).
AUTH_PROVIDER=dev
SESSION_SECRET=dev-insecure-secret

# Mockup database (matches db/ defaults). App connects as the seeded `toma` user.
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=toma
MARIADB_PASSWORD=toma
MARIADB_DATABASE=coma
